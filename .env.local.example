# Compás — variables de entorno
#
# La app FUNCIONA SIN CONFIGURAR NADA (modo local con localStorage).
# Rellena estas variables solo cuando quieras persistencia real multi-academia con Supabase.

# Supabase (modo nube multi-academia)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# URL pública de la app (para generar enlaces/QR de academia)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Email del administrador de la plataforma (acceso a /admin con todas las academias).
# Déjalo vacío si no usas panel de plataforma.
NEXT_PUBLIC_ADMIN_EMAIL=
